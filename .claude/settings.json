{
  "permissions": {
    "allow": [
      "Bash(curl -s http://localhost:8080)",
      "Bash(pkill -f \"vue-cli-service serve\" 2>/dev/null; sleep 1; nohup npm start > /tmp/devsrv.log 2>&1 & *)",
      "Bash(node --check src/views/Embarques/components/CuentaFletes/cuentaFletesUtils.js)"
    ],
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
